{
  "kind": "collectionType",
  "collectionName": "voluntarios",
  "info": {
    "singularName": "voluntario",
    "pluralName": "voluntarios",
    "displayName": "Voluntario"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nome": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true
    },
    "cidade": {
      "type": "string",
      "required": true
    },
    "solicitacoes_voluntario": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::ong.ong",
      "mappedBy": "solicitacoes"
    },
    "users_permissions_user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
